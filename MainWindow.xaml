<Window x:Class="ClassicPhotoViewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:skia="clr-namespace:SkiaSharp.Views.WPF;assembly=SkiaSharp.Views.WPF"
        mc:Ignorable="d"
        Title=""
        Width="1080"
        Height="720"
        MinWidth="520"
        MinHeight="360"
        Background="#EAF4FF"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        AllowDrop="True"
        DragOver="Window_DragOver"
        Drop="Window_Drop"
        SizeChanged="Window_SizeChanged"
        KeyDown="Window_KeyDown">
    <Window.Resources>
        <SolidColorBrush x:Key="ToolbarControlForeground" Color="#1F2933" />
        <LinearGradientBrush x:Key="ToolbarButtonBackground" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#FFFFFF" Offset="0" />
            <GradientStop Color="#F3F6F9" Offset="0.52" />
            <GradientStop Color="#E4EAF0" Offset="1" />
        </LinearGradientBrush>
        <SolidColorBrush x:Key="ToolbarButtonBorder" Color="#9AA7B5" />
        <SolidColorBrush x:Key="ToolbarButtonHoverBorder" Color="#6A9ED6" />
        <SolidColorBrush x:Key="ToolbarButtonPressedBackground" Color="#DCEEFF" />
        <SolidColorBrush x:Key="ToolbarButtonDisabledBackground" Color="#F6F8FA" />
        <SolidColorBrush x:Key="ToolbarButtonDisabledBorder" Color="#CFD6DE" />
        <SolidColorBrush x:Key="ToolbarButtonShadow" Color="#6F7F91" />
        <SolidColorBrush x:Key="ToolbarButtonShell" Color="#55FFFFFF" />

        <SolidColorBrush x:Key="ToolbarToggleBackground" Color="#FFFFFF" />
        <SolidColorBrush x:Key="ToolbarToggleCheckedBackground" Color="#EAF4FF" />
        <SolidColorBrush x:Key="ToolbarToggleBorder" Color="#B6BDC6" />
        <SolidColorBrush x:Key="ToolbarToggleCheckedBorder" Color="#6A9ED6" />

        <SolidColorBrush x:Key="ToolbarComboBackground" Color="#FFFFFF" />
        <SolidColorBrush x:Key="ToolbarComboBorder" Color="#B6BDC6" />
        <SolidColorBrush x:Key="ToolbarComboPopupBackground" Color="#FFFFFF" />

        <Style x:Key="ToolbarButtonStyle" TargetType="Button">
            <Setter Property="MinWidth" Value="42" />
            <Setter Property="Width" Value="42" />
            <Setter Property="Height" Value="27" />
            <Setter Property="Margin" Value="4,0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="{DynamicResource ToolbarControlForeground}" />
            <Setter Property="Background" Value="{DynamicResource ToolbarButtonBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ToolbarButtonBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="ButtonShell"
                                    CornerRadius="13"
                                    Background="{DynamicResource ToolbarButtonShell}"
                                    Margin="0,1,0,0">
                                <Border.Effect>
                                    <DropShadowEffect Color="{Binding Color, Source={StaticResource ToolbarButtonShadow}}"
                                                      Direction="270"
                                                      ShadowDepth="1"
                                                      BlurRadius="2"
                                                      Opacity="0.16" />
                                </Border.Effect>
                            </Border>
                            <Border x:Name="ButtonBorder"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="13"
                                    Background="{TemplateBinding Background}"
                                    SnapsToDevicePixels="True">
                                <ContentPresenter x:Name="ButtonContent"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  RecognizesAccessKey="True" />
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{DynamicResource ToolbarButtonHoverBorder}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource ToolbarButtonPressedBackground}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource ToolbarButtonDisabledBackground}" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{DynamicResource ToolbarButtonDisabledBorder}" />
                                <Setter TargetName="ButtonShell" Property="Opacity" Value="0" />
                                <Setter TargetName="ButtonContent" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ToolbarToggleStyle" TargetType="ToggleButton">
            <Setter Property="MinWidth" Value="74" />
            <Setter Property="Height" Value="27" />
            <Setter Property="Margin" Value="4,0" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{DynamicResource ToolbarControlForeground}" />
            <Setter Property="Background" Value="{DynamicResource ToolbarButtonBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ToolbarButtonBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid>
                            <Border x:Name="ToggleShell"
                                    Background="{DynamicResource ToolbarButtonShell}"
                                    CornerRadius="13"
                                    Margin="0,1,0,0">
                                <Border.Effect>
                                    <DropShadowEffect Color="{Binding Color, Source={StaticResource ToolbarButtonShadow}}"
                                                      Direction="270"
                                                      ShadowDepth="1"
                                                      BlurRadius="2"
                                                      Opacity="0.14" />
                                </Border.Effect>
                            </Border>
                            <Border x:Name="ToggleBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="13"
                                    SnapsToDevicePixels="True">
                                <ContentPresenter x:Name="ToggleContent"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ToggleBorder" Property="Background" Value="{DynamicResource ToolbarButtonPressedBackground}" />
                                <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="{DynamicResource ToolbarButtonBorder}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="{DynamicResource ToolbarButtonHoverBorder}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ToggleBorder" Property="Background" Value="{DynamicResource ToolbarButtonDisabledBackground}" />
                                <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="{DynamicResource ToolbarButtonDisabledBorder}" />
                                <Setter TargetName="ToggleShell" Property="Opacity" Value="0" />
                                <Setter TargetName="ToggleContent" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ToolbarComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Width" Value="66" />
            <Setter Property="Height" Value="27" />
            <Setter Property="Margin" Value="4,0" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{DynamicResource ToolbarControlForeground}" />
            <Setter Property="Background" Value="{DynamicResource ToolbarButtonBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ToolbarButtonBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground" Value="{DynamicResource ToolbarControlForeground}" />
                        <Setter Property="Background" Value="{DynamicResource ToolbarComboPopupBackground}" />
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ComboToggle"
                                          Focusable="False"
                                          Foreground="{TemplateBinding Foreground}"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="ComboBorder"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="13"
                                                SnapsToDevicePixels="True">
                                            <Grid>
                                                <ContentPresenter Margin="8,0,20,0"
                                                                  HorizontalAlignment="Left"
                                                                  VerticalAlignment="Center"
                                                                  Content="{Binding SelectionBoxItem, RelativeSource={RelativeSource AncestorType=ComboBox}}" />
                                                <Path HorizontalAlignment="Right"
                                                      VerticalAlignment="Center"
                                                      Margin="0,0,7,0"
                                                      Data="M0,0 L4,4 L8,0 Z"
                                                      Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ComboBox}}" />
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="{DynamicResource ToolbarButtonHoverBorder}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup x:Name="Popup"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Placement="Bottom"
                                   Focusable="False"
                                   PopupAnimation="Fade">
                                <Border Background="{DynamicResource ToolbarComboPopupBackground}"
                                        BorderBrush="{DynamicResource ToolbarComboBorder}"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        MinWidth="{TemplateBinding ActualWidth}">
                                    <ScrollViewer SnapsToDevicePixels="True">
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ThemeSwitchStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="52" />
            <Setter Property="Height" Value="26" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid Width="52" Height="26">
                            <Border x:Name="SwitchTrack"
                                    CornerRadius="13"
                                    Background="{DynamicResource ToolbarButtonBackground}"
                                    BorderBrush="{DynamicResource ToolbarButtonBorder}"
                                    BorderThickness="1">
                                <Border.Effect>
                                    <DropShadowEffect Color="{Binding Color, Source={StaticResource ToolbarButtonShadow}}"
                                                      Direction="270"
                                                      ShadowDepth="1"
                                                      BlurRadius="2"
                                                      Opacity="0.16" />
                                </Border.Effect>
                            </Border>
                            <Grid x:Name="SwitchThumb"
                                  Width="20"
                                  Height="20"
                                  Margin="3,0,0,0"
                                  HorizontalAlignment="Left"
                                  VerticalAlignment="Center">
                                <Ellipse Fill="{DynamicResource ToolbarComboBackground}"
                                         Stroke="{DynamicResource ToolbarButtonBorder}"
                                         StrokeThickness="1" />
                                <Path x:Name="SwitchMark"
                                      Data="M10,4.5 L10,5.9 M10,14.1 L10,15.5 M4.5,10 L5.9,10 M14.1,10 L15.5,10 M6.1,6.1 L7.1,7.1 M12.9,12.9 L13.9,13.9 M13.9,6.1 L12.9,7.1 M7.1,12.9 L6.1,13.9 M12.4,10 A2.4,2.4 0 1 1 7.6,10 A2.4,2.4 0 1 1 12.4,10"
                                      Stroke="{DynamicResource ToolbarControlForeground}"
                                      StrokeThickness="1.25"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round" />
                            </Grid>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="SwitchThumb" Property="Margin" Value="29,0,0,0" />
                                <Setter TargetName="SwitchMark" Property="Data" Value="M13.7,5.6 C12.1,6.7 11.6,9 12.6,10.8 C13.4,12.2 14.9,12.9 16.3,12.8 C15.5,15 12.9,16.4 10.4,15.8 C7.5,15.1 5.9,12.2 6.7,9.3 C7.3,7 9.4,5.5 13.7,5.6 Z" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="SwitchTrack" Property="BorderBrush" Value="#6A9ED6" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="38" />
        </Grid.RowDefinitions>

        <skia:SKElement x:Name="ImageSurface"
                        PaintSurface="ImageSurface_PaintSurface"
                        MouseWheel="ImageSurface_MouseWheel"
                        MouseDown="ImageSurface_MouseDown"
                        MouseMove="ImageSurface_MouseMove"
                        MouseUp="ImageSurface_MouseUp"
                        LostMouseCapture="ImageSurface_LostMouseCapture"
                        SizeChanged="ImageSurface_SizeChanged"
                        Focusable="True" />

        <Border x:Name="StatusOverlay"
                Grid.Row="0"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="#DDEAF6FF"
                BorderBrush="#8EA9C7"
                BorderThickness="1"
                CornerRadius="3"
                Padding="18,12">
            <TextBlock x:Name="StatusText"
                       Text=""
                       Foreground="#1F2933"
                       FontSize="14"
                       TextAlignment="Center"
                       TextTrimming="CharacterEllipsis"
                       TextWrapping="Wrap" />
        </Border>

        <Border x:Name="PreviewOnlyBadge"
                Grid.Row="0"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Margin="12,12,0,0"
                Background="#EFFFFFFF"
                BorderBrush="#D6A245"
                BorderThickness="1"
                CornerRadius="3"
                Padding="9,5"
                Visibility="Collapsed">
            <TextBlock x:Name="PreviewOnlyText"
                       Text=""
                       Foreground="#664500"
                       FontSize="12" />
        </Border>

        <ToggleButton x:Name="ThemeToggleButton"
                      Grid.Row="0"
                      HorizontalAlignment="Right"
                      VerticalAlignment="Top"
                      Margin="0,10,12,0"
                      Style="{StaticResource ThemeSwitchStyle}"
                      Click="ThemeToggleButton_Click" />

        <Border x:Name="ToolbarHost"
                Grid.Row="1"
                Background="#FFFFFF"
                BorderBrush="#D1D5DB"
                BorderThickness="1,1,1,0">
            <Grid Margin="10,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button x:Name="PreviousButton"
                            Style="{StaticResource ToolbarButtonStyle}"
                            Click="PreviousButton_Click" />
                    <Button x:Name="NextButton"
                            Style="{StaticResource ToolbarButtonStyle}"
                            Click="NextButton_Click" />
                </StackPanel>

                <Grid Grid.Column="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Button x:Name="ActualPixelsButton"
                            Grid.Column="0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Style="{StaticResource ToolbarButtonStyle}"
                            Click="ActualPixelsButton_Click" />

                    <StackPanel x:Name="AdvancedControlsPanel"
                                Grid.Column="1"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <TextBlock x:Name="ZoomText"
                                   Margin="0,0,8,0"
                                   VerticalAlignment="Center"
                                   Foreground="#334155"
                                   FontSize="12" />
                        <ToggleButton x:Name="SamplingToggleButton"
                                      Style="{StaticResource ToolbarToggleStyle}"
                                      IsChecked="True"
                                      Click="SamplingToggleButton_Click" />
                        <ToggleButton x:Name="PreloadToggleButton"
                                      Style="{StaticResource ToolbarToggleStyle}"
                                      IsChecked="True"
                                      Click="PreloadToggleButton_Click" />
                        <ComboBox x:Name="PreloadBudgetComboBox"
                                  Style="{StaticResource ToolbarComboBoxStyle}"
                                  SelectedIndex="1"
                                  SelectionChanged="PreloadBudgetComboBox_SelectionChanged">
                            <ComboBoxItem Content="1 GB" Tag="1" />
                            <ComboBoxItem Content="2 GB" Tag="2" />
                            <ComboBoxItem Content="5 GB" Tag="5" />
                            <ComboBoxItem Content="10 GB" Tag="10" />
                            <ComboBoxItem Content="15 GB" Tag="15" />
                        </ComboBox>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
