<Window x:Class="Mangosteen.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:skia="clr-namespace:SkiaSharp.Views.WPF;assembly=SkiaSharp.Views.WPF"
        mc:Ignorable="d"
        Title=""
        Width="1080"
        Height="720"
        MinWidth="520"
        MinHeight="360"
        Background="#F4F6F8"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        AllowDrop="True"
        DragOver="Window_DragOver"
        Drop="Window_Drop"
        Icon="Assets/mangosteen.ico"
        SizeChanged="Window_SizeChanged"
        KeyDown="Window_KeyDown">
    <Window.Resources>
        <!-- Shared design tokens: one surface language for menu bar, menus, dock, and overlays.
             Values here are the light theme; ApplyToolbarThemeResources swaps them per theme. -->
        <SolidColorBrush x:Key="PanelBackground" Color="#FFFFFF" />
        <SolidColorBrush x:Key="PanelBorder" Color="#D4DBE3" />
        <SolidColorBrush x:Key="PanelSeparator" Color="#E2E8EE" />
        <SolidColorBrush x:Key="ControlHoverBackground" Color="#EBF1F7" />
        <SolidColorBrush x:Key="ControlPressedBackground" Color="#DDE6EF" />
        <SolidColorBrush x:Key="TextPrimary" Color="#243240" />
        <SolidColorBrush x:Key="TextSecondary" Color="#5E6C7A" />
        <SolidColorBrush x:Key="TextDisabled" Color="#93A0AD" />
        <SolidColorBrush x:Key="TextDanger" Color="#B23730" />
        <SolidColorBrush x:Key="AccentCheckBackground" Color="#E8F1FB" />
        <SolidColorBrush x:Key="AccentCheckBorder" Color="#7FA8D1" />
        <SolidColorBrush x:Key="BadgeBackground" Color="#FFF7E4" />
        <SolidColorBrush x:Key="BadgeBorder" Color="#D9A03F" />
        <SolidColorBrush x:Key="BadgeForeground" Color="#6B4A00" />
        <Style x:Key="{x:Static MenuItem.SeparatorStyleKey}" TargetType="Separator">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Separator">
                        <Border Height="1"
                                Margin="30,4,8,4"
                                Background="{DynamicResource PanelSeparator}" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="MenuItem">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Height" Value="28" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="ToolTipService.InitialShowDelay" Value="350" />
            <Setter Property="ToolTipService.ShowDuration" Value="12000" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Grid SnapsToDevicePixels="True">
                            <Border x:Name="TopLevelBorder"
                                    Margin="2,2"
                                    Padding="11,0"
                                    Background="Transparent"
                                    CornerRadius="6"
                                    Visibility="Collapsed">
                                <ContentPresenter ContentSource="Header"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  RecognizesAccessKey="True" />
                            </Border>

                            <Border x:Name="SubmenuBorder"
                                    MinHeight="28"
                                    Margin="3,1"
                                    Padding="0"
                                    Background="Transparent"
                                    CornerRadius="5">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="28" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="18" />
                                    </Grid.ColumnDefinitions>

                                    <Border x:Name="CheckBox"
                                            Grid.Column="0"
                                            Width="22"
                                            Height="22"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Background="Transparent"
                                            BorderBrush="Transparent"
                                            BorderThickness="1">
                                        <Path x:Name="CheckGlyph"
                                              Data="M5.25,11.5 L9,15.25 L16.75,6.75"
                                              Stroke="{Binding Foreground, RelativeSource={RelativeSource TemplatedParent}}"
                                              StrokeThickness="1.8"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              StrokeLineJoin="Round"
                                              Visibility="Collapsed" />
                                    </Border>

                                    <ContentPresenter Grid.Column="1"
                                                      Margin="2,0,22,0"
                                                      VerticalAlignment="Center"
                                                      ContentSource="Header"
                                                      RecognizesAccessKey="True" />

                                    <TextBlock Grid.Column="2"
                                               Margin="14,0,8,0"
                                               VerticalAlignment="Center"
                                               Foreground="{Binding Foreground, RelativeSource={RelativeSource TemplatedParent}}"
                                               Text="{TemplateBinding InputGestureText}" />

                                    <Path x:Name="SubmenuArrow"
                                          Grid.Column="3"
                                          Width="4"
                                          Height="8"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Data="M0,0 L4,4 L0,8 Z"
                                          Fill="{Binding Foreground, RelativeSource={RelativeSource TemplatedParent}}"
                                          Stretch="Fill" />
                                </Grid>
                            </Border>

                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   HorizontalOffset="3"
                                   Placement="Right"
                                   PlacementTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                                   PopupAnimation="None">
                                <Border MinWidth="220"
                                        Padding="1,3"
                                        Background="{DynamicResource PanelBackground}"
                                        BorderBrush="{DynamicResource PanelBorder}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        SnapsToDevicePixels="True">
                                    <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Cycle" />
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Role" Value="TopLevelHeader">
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
                                <Setter TargetName="TopLevelBorder" Property="Visibility" Value="Visible" />
                                <Setter TargetName="SubmenuBorder" Property="Visibility" Value="Collapsed" />
                                <Setter TargetName="PART_Popup" Property="HorizontalOffset" Value="0" />
                                <Setter TargetName="PART_Popup" Property="Placement" Value="Bottom" />
                                <Setter TargetName="PART_Popup" Property="VerticalOffset" Value="0" />
                            </Trigger>
                            <Trigger Property="Role" Value="TopLevelItem">
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
                                <Setter TargetName="TopLevelBorder" Property="Visibility" Value="Visible" />
                                <Setter TargetName="SubmenuBorder" Property="Visibility" Value="Collapsed" />
                            </Trigger>
                            <Trigger Property="Role" Value="SubmenuItem">
                                <Setter TargetName="SubmenuArrow" Property="Visibility" Value="Collapsed" />
                            </Trigger>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="TopLevelBorder" Property="Background" Value="{DynamicResource ControlHoverBackground}" />
                                <Setter TargetName="SubmenuBorder" Property="Background" Value="{DynamicResource ControlHoverBackground}" />
                            </Trigger>
                            <Trigger Property="IsSubmenuOpen" Value="True">
                                <Setter TargetName="TopLevelBorder" Property="Background" Value="{DynamicResource ControlPressedBackground}" />
                                <Setter TargetName="SubmenuBorder" Property="Background" Value="{DynamicResource ControlPressedBackground}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckBox" Property="Background" Value="{DynamicResource AccentCheckBackground}" />
                                <Setter TargetName="CheckBox" Property="BorderBrush" Value="{DynamicResource AccentCheckBorder}" />
                                <Setter TargetName="CheckGlyph" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{DynamicResource TextDisabled}" />
                                <Setter TargetName="CheckBox" Property="Opacity" Value="0.55" />
                                <Setter TargetName="SubmenuArrow" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DockButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="38" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Margin" Value="1,0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="ToolTipService.ShowOnDisabled" Value="True" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                SnapsToDevicePixels="True">
                            <ContentPresenter x:Name="ButtonContent"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource ControlHoverBackground}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource ControlPressedBackground}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonContent" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="28" />
            <RowDefinition Height="*" />
            <RowDefinition Height="48" />
        </Grid.RowDefinitions>

        <Menu x:Name="MainMenu"
              Grid.Row="0"
              Background="{DynamicResource PanelBackground}"
              Foreground="{DynamicResource TextPrimary}"
              BorderBrush="{DynamicResource PanelBorder}"
              BorderThickness="0,0,0,1">
            <MenuItem x:Name="FileMenuItem">
                <MenuItem x:Name="OpenMenuItem"
                          Click="OpenMenuItem_Click" />
                <MenuItem x:Name="DeleteMenuItem"
                          Click="DeleteMenuItem_Click" />
                <Separator />
                <MenuItem x:Name="ExitMenuItem"
                          Click="ExitMenuItem_Click" />
            </MenuItem>
            <MenuItem x:Name="OptionsMenuItem">
                <MenuItem x:Name="SamplingMenuItem">
                    <MenuItem x:Name="SmoothSamplingMenuItem"
                              IsCheckable="True"
                              IsChecked="True"
                              Click="SmoothSamplingMenuItem_Click" />
                    <MenuItem x:Name="NearestSamplingMenuItem"
                              IsCheckable="True"
                              Click="NearestSamplingMenuItem_Click" />
                </MenuItem>
                <MenuItem x:Name="PreloadEnabledMenuItem"
                          IsCheckable="True"
                          IsChecked="True"
                          Click="PreloadEnabledMenuItem_Click" />
                <MenuItem x:Name="PreloadMemoryBudgetMenuItem">
                    <MenuItem IsCheckable="True"
                              Header="1 GB"
                              Tag="1"
                              Click="PreloadBudgetMenuItem_Click" />
                    <MenuItem IsCheckable="True"
                              Header="2 GB"
                              Tag="2"
                              IsChecked="True"
                              Click="PreloadBudgetMenuItem_Click" />
                    <MenuItem IsCheckable="True"
                              Header="5 GB"
                              Tag="5"
                              Click="PreloadBudgetMenuItem_Click" />
                    <MenuItem IsCheckable="True"
                              Header="10 GB"
                              Tag="10"
                              Click="PreloadBudgetMenuItem_Click" />
                    <MenuItem IsCheckable="True"
                              Header="15 GB"
                              Tag="15"
                              Click="PreloadBudgetMenuItem_Click" />
                </MenuItem>
                <MenuItem x:Name="PreloadAggressivenessMenuItem">
                    <MenuItem x:Name="ConservativePreloadMenuItem"
                              IsCheckable="True"
                              Tag="Conservative"
                              Click="PreloadAggressivenessMenuItem_Click" />
                    <MenuItem x:Name="BalancedPreloadMenuItem"
                              IsCheckable="True"
                              Tag="Balanced"
                              IsChecked="True"
                              Click="PreloadAggressivenessMenuItem_Click" />
                    <MenuItem x:Name="AggressivePreloadMenuItem"
                              IsCheckable="True"
                              Tag="Aggressive"
                              Click="PreloadAggressivenessMenuItem_Click" />
                </MenuItem>
                <Separator />
                <MenuItem x:Name="DarkModeMenuItem"
                          IsCheckable="True"
                          Click="DarkModeMenuItem_Click" />
            </MenuItem>
            <MenuItem x:Name="HelpMenuItem">
                <MenuItem x:Name="OptionsHelpMenuItem"
                          Click="OptionsHelpMenuItem_Click" />
            </MenuItem>
        </Menu>

        <skia:SKElement x:Name="ImageSurface"
                        Grid.Row="1"
                        Margin="0,8,0,0"
                        PaintSurface="ImageSurface_PaintSurface"
                        MouseWheel="ImageSurface_MouseWheel"
                        MouseDown="ImageSurface_MouseDown"
                        MouseMove="ImageSurface_MouseMove"
                        MouseUp="ImageSurface_MouseUp"
                        LostMouseCapture="ImageSurface_LostMouseCapture"
                        SizeChanged="ImageSurface_SizeChanged"
                        Focusable="True" />

        <Border x:Name="StatusOverlay"
                Grid.Row="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="{DynamicResource PanelBackground}"
                BorderBrush="{DynamicResource PanelBorder}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="18,12">
            <TextBlock x:Name="StatusText"
                       Text=""
                       Foreground="{DynamicResource TextPrimary}"
                       FontSize="14"
                       TextAlignment="Center"
                       TextTrimming="CharacterEllipsis"
                       TextWrapping="Wrap" />
        </Border>

        <Border x:Name="PreviewOnlyBadge"
                Grid.Row="1"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Margin="12,12,0,0"
                Background="{DynamicResource BadgeBackground}"
                BorderBrush="{DynamicResource BadgeBorder}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="9,5"
                Visibility="Collapsed">
            <TextBlock x:Name="PreviewOnlyText"
                       Text=""
                       Foreground="{DynamicResource BadgeForeground}"
                       FontSize="12" />
        </Border>

        <Border x:Name="ToolbarHost"
                Grid.Row="2"
                Background="Transparent"
                BorderThickness="0">
            <Border x:Name="CommandDock"
                    Margin="10,0"
                    Padding="5,4"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="{DynamicResource PanelBackground}"
                    BorderBrush="{DynamicResource PanelBorder}"
                    BorderThickness="1"
                    CornerRadius="10"
                    SnapsToDevicePixels="True">
                <Border.Effect>
                    <DropShadowEffect Color="#000000"
                                      Direction="270"
                                      ShadowDepth="1"
                                      BlurRadius="8"
                                      Opacity="0.10" />
                </Border.Effect>
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button x:Name="PreviousButton"
                            Style="{StaticResource DockButtonStyle}"
                            Click="PreviousButton_Click" />
                    <Button x:Name="NextButton"
                            Style="{StaticResource DockButtonStyle}"
                            Click="NextButton_Click" />
                    <Rectangle Width="1"
                               Height="18"
                               Margin="6,0"
                               VerticalAlignment="Center"
                               Fill="{DynamicResource PanelSeparator}" />
                    <Button x:Name="ActualPixelsButton"
                            Style="{StaticResource DockButtonStyle}"
                            Click="ActualPixelsButton_Click" />
                    <TextBlock x:Name="ZoomText"
                               MinWidth="44"
                               Margin="2,0"
                               VerticalAlignment="Center"
                               TextAlignment="Center"
                               FontSize="12"
                               Foreground="{DynamicResource TextSecondary}" />
                    <Rectangle Width="1"
                               Height="18"
                               Margin="6,0"
                               VerticalAlignment="Center"
                               Fill="{DynamicResource PanelSeparator}" />
                    <Button x:Name="DeleteButton"
                            Style="{StaticResource DockButtonStyle}"
                            Click="DeleteButton_Click" />
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Window>
