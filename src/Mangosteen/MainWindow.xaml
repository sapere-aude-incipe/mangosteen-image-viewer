<Window x:Class="Mangosteen.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:skia="clr-namespace:SkiaSharp.Views.WPF;assembly=SkiaSharp.Views.WPF"
        xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title=""
        Width="1080"
        Height="720"
        MinWidth="520"
        MinHeight="360"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="#1E2126"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        AllowDrop="True"
        DragOver="Window_DragOver"
        Drop="Window_Drop"
        PreviewMouseDown="Window_PreviewMouseDown"
        Icon="Assets/mangosteen.ico"
        SourceInitialized="Window_SourceInitialized"
        SizeChanged="Window_SizeChanged"
        StateChanged="Window_StateChanged"
        KeyDown="Window_KeyDown">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="48"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="6"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- Shared design tokens: one surface language for menu bar, menus, dock, and overlays.
             Values here match the default dark theme so startup does not rebuild every brush. -->
        <SolidColorBrush x:Key="ChromeBackground" Color="#1E2126" />
        <SolidColorBrush x:Key="ChromeSurfaceBackground" Color="#272B32" />
        <SolidColorBrush x:Key="ChromeSurfaceBorder" Color="#3E4550" />
        <SolidColorBrush x:Key="ChromeButtonForeground" Color="#ECF0F5" />
        <SolidColorBrush x:Key="ChromeButtonHoverBackground" Color="#363D48" />
        <SolidColorBrush x:Key="ChromeButtonPressedBackground" Color="#404854" />
        <SolidColorBrush x:Key="ChromeCloseHoverBackground" Color="#C42B1C" />
        <SolidColorBrush x:Key="ChromeCloseHoverForeground" Color="#FFFFFF" />
        <SolidColorBrush x:Key="EmptyStateBackground" Color="#0EFFFFFF" />
        <SolidColorBrush x:Key="EmptyStateBorder" Color="#606872" />
        <SolidColorBrush x:Key="EmptyStateIcon" Color="#969DA6" />
        <SolidColorBrush x:Key="PanelBackground" Color="#2B2F36" />
        <SolidColorBrush x:Key="PanelBorder" Color="#464C56" />
        <SolidColorBrush x:Key="PanelSeparator" Color="#3E444E" />
        <SolidColorBrush x:Key="ControlHoverBackground" Color="#3C434D" />
        <SolidColorBrush x:Key="ControlPressedBackground" Color="#48505C" />
        <SolidColorBrush x:Key="TextPrimary" Color="#ECF0F5" />
        <SolidColorBrush x:Key="TextSecondary" Color="#A0AAB6" />
        <SolidColorBrush x:Key="TextDisabled" Color="#7A8490" />
        <SolidColorBrush x:Key="TextDanger" Color="#EB8780" />
        <SolidColorBrush x:Key="AccentCheckBackground" Color="#34485E" />
        <SolidColorBrush x:Key="AccentCheckBorder" Color="#78AADC" />
        <SolidColorBrush x:Key="BadgeBackground" Color="#3A3526" />
        <SolidColorBrush x:Key="BadgeBorder" Color="#8A6D2F" />
        <SolidColorBrush x:Key="BadgeForeground" Color="#E8C97A" />
        <Style x:Key="{x:Static MenuItem.SeparatorStyleKey}" TargetType="Separator">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Separator">
                        <Border Height="1"
                                Margin="32,4,12,4"
                                Background="{DynamicResource PanelSeparator}" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ThemedContextMenuStyle" TargetType="ContextMenu">
            <Setter Property="Background" Value="{DynamicResource PanelBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource PanelBorder}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border MinWidth="230"
                                Padding="4"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="10"
                                SnapsToDevicePixels="True">
                            <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Cycle" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="MenuItem">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Height" Value="32" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="ToolTipService.InitialShowDelay" Value="350" />
            <Setter Property="ToolTipService.ShowDuration" Value="12000" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Grid SnapsToDevicePixels="True">
                            <Border x:Name="TopLevelBorder"
                                    Margin="1,2"
                                    Padding="10,0"
                                    Background="Transparent"
                                    CornerRadius="6"
                                    Visibility="Collapsed">
                                <ContentPresenter ContentSource="Header"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  RecognizesAccessKey="True" />
                            </Border>

                            <Border x:Name="SubmenuBorder"
                                    MinHeight="28"
                                    Margin="3,1"
                                    Padding="0"
                                    Background="Transparent"
                                    CornerRadius="6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="28" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="20" />
                                    </Grid.ColumnDefinitions>

                                    <Border x:Name="CheckBox"
                                            Grid.Column="0"
                                            Width="16"
                                            Height="16"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Background="Transparent"
                                            BorderBrush="Transparent"
                                            BorderThickness="1"
                                            CornerRadius="2">
                                        <Path x:Name="CheckGlyph"
                                              Width="10"
                                              Height="7"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Data="M0,3.5 L3.5,7 L10,0"
                                              Stroke="{Binding Foreground, RelativeSource={RelativeSource TemplatedParent}}"
                                              StrokeThickness="1.6"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              StrokeLineJoin="Round"
                                              Stretch="Fill"
                                              Visibility="Collapsed" />
                                    </Border>

                                    <ContentPresenter Grid.Column="1"
                                                      Margin="4,0,14,0"
                                                      VerticalAlignment="Center"
                                                      ContentSource="Header"
                                                      RecognizesAccessKey="True" />

                                    <TextBlock Grid.Column="2"
                                               Margin="12,0,8,0"
                                               VerticalAlignment="Center"
                                               Foreground="{Binding Foreground, RelativeSource={RelativeSource TemplatedParent}}"
                                               Text="{TemplateBinding InputGestureText}" />

                                    <Path x:Name="SubmenuArrow"
                                          Grid.Column="3"
                                          Width="5"
                                          Height="9"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Data="M0,0 L4,4 L0,8 Z"
                                          Fill="{Binding Foreground, RelativeSource={RelativeSource TemplatedParent}}"
                                          Stretch="Fill" />
                                </Grid>
                            </Border>

                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   HorizontalOffset="2"
                                   Placement="Right"
                                   PlacementTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                                   PopupAnimation="None">
                                <Border MinWidth="220"
                                        Padding="4"
                                        Background="{DynamicResource PanelBackground}"
                                        BorderBrush="{DynamicResource PanelBorder}"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        SnapsToDevicePixels="True">
                                    <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Cycle" />
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Role" Value="TopLevelHeader">
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
                                <Setter TargetName="TopLevelBorder" Property="Visibility" Value="Visible" />
                                <Setter TargetName="SubmenuBorder" Property="Visibility" Value="Collapsed" />
                                <Setter TargetName="PART_Popup" Property="HorizontalOffset" Value="0" />
                                <Setter TargetName="PART_Popup" Property="Placement" Value="Bottom" />
                                <Setter TargetName="PART_Popup" Property="VerticalOffset" Value="0" />
                            </Trigger>
                            <Trigger Property="Role" Value="TopLevelItem">
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
                                <Setter TargetName="TopLevelBorder" Property="Visibility" Value="Visible" />
                                <Setter TargetName="SubmenuBorder" Property="Visibility" Value="Collapsed" />
                            </Trigger>
                            <Trigger Property="Role" Value="SubmenuItem">
                                <Setter TargetName="SubmenuArrow" Property="Visibility" Value="Collapsed" />
                            </Trigger>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="TopLevelBorder" Property="Background" Value="{DynamicResource ControlHoverBackground}" />
                                <Setter TargetName="SubmenuBorder" Property="Background" Value="{DynamicResource ControlHoverBackground}" />
                            </Trigger>
                            <Trigger Property="IsSubmenuOpen" Value="True">
                                <Setter TargetName="TopLevelBorder" Property="Background" Value="{DynamicResource ControlPressedBackground}" />
                                <Setter TargetName="SubmenuBorder" Property="Background" Value="{DynamicResource ControlPressedBackground}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckBox" Property="Background" Value="{DynamicResource AccentCheckBackground}" />
                                <Setter TargetName="CheckBox" Property="BorderBrush" Value="{DynamicResource AccentCheckBorder}" />
                                <Setter TargetName="CheckGlyph" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{DynamicResource TextDisabled}" />
                                <Setter TargetName="CheckBox" Property="Opacity" Value="0.55" />
                                <Setter TargetName="SubmenuArrow" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DockButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="38" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Margin" Value="1,0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="ToolTipService.ShowOnDisabled" Value="True" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="5"
                                SnapsToDevicePixels="True">
                            <ContentPresenter x:Name="ButtonContent"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource ControlHoverBackground}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource ControlPressedBackground}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ChromeWindowButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="46" />
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource ChromeButtonForeground}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonSurface"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonSurface" Property="Background" Value="{DynamicResource ChromeButtonHoverBackground}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonSurface" Property="Background" Value="{DynamicResource ChromeButtonPressedBackground}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ChromeCaptionGlyphStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe Fluent Icons, Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="Normal" />
            <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="UseLayoutRounding" Value="True" />
            <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
            <Setter Property="TextOptions.TextHintingMode" Value="Fixed" />
        </Style>

        <Style x:Key="ChromeCloseButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource ChromeWindowButtonStyle}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonSurface"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonSurface" Property="Background" Value="{DynamicResource ChromeCloseHoverBackground}" />
                                <Setter Property="Foreground" Value="{DynamicResource ChromeCloseHoverForeground}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonSurface" Property="Background" Value="#8B1A10" />
                                <Setter Property="Foreground" Value="{DynamicResource ChromeCloseHoverForeground}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ZoomSliderTrackButtonStyle" TargetType="{x:Type primitives:RepeatButton}">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Background" Value="{DynamicResource PanelSeparator}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type primitives:RepeatButton}">
                        <Border Height="4"
                                VerticalAlignment="Center"
                                Background="{TemplateBinding Background}"
                                CornerRadius="2" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ZoomSliderThumbStyle" TargetType="{x:Type primitives:Thumb}">
            <Setter Property="Width" Value="14" />
            <Setter Property="Height" Value="14" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type primitives:Thumb}">
                        <Ellipse Fill="{DynamicResource TextPrimary}"
                                 Stroke="{DynamicResource PanelBackground}"
                                 StrokeThickness="2"
                                 SnapsToDevicePixels="True" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DockZoomSliderStyle" TargetType="Slider">
            <Setter Property="Width" Value="132" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Minimum" Value="0" />
            <Setter Property="Maximum" Value="100" />
            <Setter Property="Orientation" Value="Horizontal" />
            <Setter Property="IsMoveToPointEnabled" Value="True" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid Height="{TemplateBinding Height}"
                              VerticalAlignment="Center">
                            <primitives:Track x:Name="PART_Track"
                                              VerticalAlignment="Center"
                                              Orientation="{TemplateBinding Orientation}"
                                              IsDirectionReversed="False">
                                <primitives:Track.DecreaseRepeatButton>
                                    <primitives:RepeatButton Command="Slider.DecreaseLarge"
                                                             Style="{StaticResource ZoomSliderTrackButtonStyle}"
                                                             Background="{DynamicResource TextPrimary}" />
                                </primitives:Track.DecreaseRepeatButton>
                                <primitives:Track.IncreaseRepeatButton>
                                    <primitives:RepeatButton Command="Slider.IncreaseLarge"
                                                             Style="{StaticResource ZoomSliderTrackButtonStyle}"
                                                             Background="{DynamicResource PanelSeparator}" />
                                </primitives:Track.IncreaseRepeatButton>
                                <primitives:Track.Thumb>
                                    <primitives:Thumb Style="{StaticResource ZoomSliderThumbStyle}" />
                                </primitives:Track.Thumb>
                            </primitives:Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ZoomPopupTextStyle" TargetType="TextBlock">
            <Setter Property="MinWidth" Value="48" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
        </Style>

        <Style x:Key="UpdateProgressBarStyle" TargetType="ProgressBar">
            <Setter Property="Width" Value="260" />
            <Setter Property="Height" Value="4" />
            <Setter Property="Minimum" Value="0" />
            <Setter Property="Maximum" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid x:Name="PART_Track"
                              ClipToBounds="True">
                            <Border Background="{DynamicResource PanelSeparator}"
                                    CornerRadius="2" />
                            <Border x:Name="PART_Indicator"
                                    HorizontalAlignment="Left"
                                    Background="{DynamicResource AccentCheckBorder}"
                                    CornerRadius="2">
                                <Border.RenderTransform>
                                    <TranslateTransform x:Name="IndeterminateTransform" />
                                </Border.RenderTransform>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsIndeterminate" Value="True">
                                <Setter TargetName="PART_Indicator" Property="Width" Value="72" />
                                <Trigger.EnterActions>
                                    <BeginStoryboard x:Name="IndeterminateAnimation">
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation Storyboard.TargetName="IndeterminateTransform"
                                                             Storyboard.TargetProperty="X"
                                                             From="-72"
                                                             To="260"
                                                             Duration="0:0:1.1" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <RemoveStoryboard BeginStoryboardName="IndeterminateAnimation" />
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RotationActionButtonStyle" TargetType="Button">
            <Setter Property="MinWidth" Value="76" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Margin" Value="2,0" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource ControlHoverBackground}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource ControlPressedBackground}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{DynamicResource TextDisabled}" />
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.72" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="UpdateCancelButtonStyle" TargetType="Button">
            <Setter Property="MinWidth" Value="104" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Margin" Value="0,10,0,0" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource PanelBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource ControlHoverBackground}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource ControlPressedBackground}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{DynamicResource TextDisabled}" />
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.72" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
            <RowDefinition Height="48" />
        </Grid.RowDefinitions>

        <Border x:Name="TopChrome"
                Grid.Row="0"
                Background="{DynamicResource ChromeBackground}">
            <Grid>
                <TextBlock x:Name="ChromeTitleText"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Margin="220,6,220,4"
                           MaxWidth="420"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimary}"
                           TextTrimming="CharacterEllipsis"
                           IsHitTestVisible="False" />

                <StackPanel HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Margin="8,6,0,0"
                            Orientation="Horizontal"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Image Width="18"
                           Height="18"
                           Margin="4,0,8,0"
                           Source="Assets/mangosteen.ico" />
                    <Menu x:Name="MainMenu"
                          Height="34"
                          Background="Transparent"
                          Foreground="{DynamicResource TextPrimary}"
                          BorderThickness="0"
                          shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <MenuItem x:Name="FileMenuItem">
                            <MenuItem x:Name="OpenMenuItem"
                                      Click="OpenMenuItem_Click" />
                            <MenuItem x:Name="DeleteMenuItem"
                                      Click="DeleteMenuItem_Click" />
                            <Separator />
                            <MenuItem x:Name="ExitMenuItem"
                                      Click="ExitMenuItem_Click" />
                        </MenuItem>
                        <MenuItem x:Name="OptionsMenuItem">
                            <MenuItem x:Name="SamplingMenuItem">
                                <MenuItem x:Name="SmoothSamplingMenuItem"
                                          IsCheckable="True"
                                          IsChecked="True"
                                          Click="SmoothSamplingMenuItem_Click" />
                                <MenuItem x:Name="NearestSamplingMenuItem"
                                          IsCheckable="True"
                                          Click="NearestSamplingMenuItem_Click" />
                            </MenuItem>
                            <MenuItem x:Name="PreloadEnabledMenuItem"
                                      IsCheckable="True"
                                      IsChecked="True"
                                      Click="PreloadEnabledMenuItem_Click" />
                            <MenuItem x:Name="PreloadMemoryBudgetMenuItem">
                                <MenuItem IsCheckable="True"
                                          Header="1 GB"
                                          Tag="1"
                                          Click="PreloadBudgetMenuItem_Click" />
                                <MenuItem IsCheckable="True"
                                          Header="2 GB"
                                          Tag="2"
                                          IsChecked="True"
                                          Click="PreloadBudgetMenuItem_Click" />
                                <MenuItem IsCheckable="True"
                                          Header="5 GB"
                                          Tag="5"
                                          Click="PreloadBudgetMenuItem_Click" />
                                <MenuItem IsCheckable="True"
                                          Header="10 GB"
                                          Tag="10"
                                          Click="PreloadBudgetMenuItem_Click" />
                                <MenuItem IsCheckable="True"
                                          Header="15 GB"
                                          Tag="15"
                                          Click="PreloadBudgetMenuItem_Click" />
                            </MenuItem>
                            <MenuItem x:Name="PreloadAggressivenessMenuItem">
                                <MenuItem x:Name="ConservativePreloadMenuItem"
                                          IsCheckable="True"
                                          Tag="Conservative"
                                          Click="PreloadAggressivenessMenuItem_Click" />
                                <MenuItem x:Name="BalancedPreloadMenuItem"
                                          IsCheckable="True"
                                          Tag="Balanced"
                                          IsChecked="True"
                                          Click="PreloadAggressivenessMenuItem_Click" />
                                <MenuItem x:Name="AggressivePreloadMenuItem"
                                          IsCheckable="True"
                                          Tag="Aggressive"
                                          Click="PreloadAggressivenessMenuItem_Click" />
                            </MenuItem>
                            <MenuItem x:Name="AutoRefreshMenuItem"
                                      IsCheckable="True"
                                      Click="AutoRefreshMenuItem_Click" />
                            <MenuItem x:Name="KeepReadyInBackgroundMenuItem"
                                      IsCheckable="True"
                                      IsChecked="True"
                                      Click="KeepReadyInBackgroundMenuItem_Click" />
                            <Separator />
                            <MenuItem x:Name="DarkModeMenuItem"
                                      IsCheckable="True"
                                      Click="DarkModeMenuItem_Click" />
                        </MenuItem>
                        <MenuItem x:Name="HelpMenuItem">
                            <MenuItem x:Name="CheckForUpdatesMenuItem"
                                      Click="CheckForUpdatesMenuItem_Click" />
                            <MenuItem x:Name="OptionsHelpMenuItem"
                                      Click="OptionsHelpMenuItem_Click" />
                        </MenuItem>
                    </Menu>
                </StackPanel>

                <StackPanel HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Orientation="Horizontal"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button x:Name="MinimizeButton"
                            Style="{StaticResource ChromeWindowButtonStyle}"
                            Click="MinimizeButton_Click"
                            ToolTip="Minimize">
                        <TextBlock Style="{StaticResource ChromeCaptionGlyphStyle}"
                                   Text="&#xE921;" />
                    </Button>
                    <Button x:Name="MaximizeRestoreButton"
                            Style="{StaticResource ChromeWindowButtonStyle}"
                            Click="MaximizeRestoreButton_Click"
                            ToolTip="Maximize">
                        <TextBlock x:Name="MaximizeRestoreIcon"
                                   Style="{StaticResource ChromeCaptionGlyphStyle}"
                                   Text="&#xE922;" />
                    </Button>
                    <Button x:Name="CloseWindowButton"
                            Style="{StaticResource ChromeCloseButtonStyle}"
                            Click="CloseWindowButton_Click"
                            ToolTip="Close">
                        <TextBlock Style="{StaticResource ChromeCaptionGlyphStyle}"
                                   Text="&#xE8BB;" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <skia:SKElement x:Name="ImageSurface"
                        Grid.Row="1"
                        PaintSurface="ImageSurface_PaintSurface"
                        MouseWheel="ImageSurface_MouseWheel"
                        MouseDown="ImageSurface_MouseDown"
                        MouseMove="ImageSurface_MouseMove"
                        MouseUp="ImageSurface_MouseUp"
                        LostMouseCapture="ImageSurface_LostMouseCapture"
                        SizeChanged="ImageSurface_SizeChanged"
                        ContextMenuOpening="ImageSurface_ContextMenuOpening"
                        Focusable="True">
            <skia:SKElement.ContextMenu>
                <ContextMenu x:Name="ImageContextMenu"
                             Style="{StaticResource ThemedContextMenuStyle}">
                    <MenuItem x:Name="ContextOpenWithMenuItem"
                              Click="ContextOpenWithMenuItem_Click" />
                    <Separator />
                    <MenuItem x:Name="ContextSetDesktopBackgroundMenuItem"
                              Click="ContextSetDesktopBackgroundMenuItem_Click" />
                    <Separator />
                    <MenuItem x:Name="ContextOpenFileLocationMenuItem"
                              Click="ContextOpenFileLocationMenuItem_Click" />
                    <Separator />
                    <MenuItem x:Name="ContextCopyMenuItem"
                              Click="ContextCopyMenuItem_Click" />
                    <MenuItem x:Name="ContextDeleteMenuItem"
                              Click="ContextDeleteMenuItem_Click" />
                    <Separator />
                    <MenuItem x:Name="ContextPropertiesMenuItem"
                              Click="ContextPropertiesMenuItem_Click" />
                </ContextMenu>
            </skia:SKElement.ContextMenu>
        </skia:SKElement>

        <Border x:Name="StatusOverlay"
                Grid.Row="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="Transparent"
                Padding="0"
                MouseWheel="ImageSurface_MouseWheel"
                MouseLeftButtonUp="StatusOverlay_MouseLeftButtonUp">
            <Grid>
                <Grid x:Name="EmptyStatePanel"
                      Width="460"
                      Height="122"
                      MinWidth="260">
                    <Rectangle RadiusX="12"
                               RadiusY="12"
                               Fill="{DynamicResource EmptyStateBackground}"
                               Stroke="{DynamicResource EmptyStateBorder}"
                               StrokeThickness="1.2"
                               StrokeDashArray="2.5 3.5"
                               SnapsToDevicePixels="True" />
                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <Viewbox Width="30"
                                 Height="30"
                                 Margin="0,0,0,11">
                            <Grid Width="24"
                                  Height="24">
                                <Path Data="M4.3,7.4 H9.4 L11.2,9.2 H19.7 V17.5 Q19.7,19.1 18.1,19.1 H5.9 Q4.3,19.1 4.3,17.5 Z M4.3,7.4 V6.5 Q4.3,5.4 5.4,5.4 H8.8 L10.6,7.4 H18.5 Q19.7,7.4 19.7,8.6 V9.2"
                                      Fill="Transparent"
                                      Stroke="{DynamicResource EmptyStateIcon}"
                                      StrokeThickness="1.45"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round" />
                            </Grid>
                        </Viewbox>
                        <TextBlock x:Name="StatusText"
                                   Text=""
                                   Foreground="{DynamicResource TextSecondary}"
                                   FontFamily="Segoe UI"
                                   FontSize="15"
                                   FontWeight="Normal"
                                   Opacity="0.88"
                                   TextAlignment="Center"
                                   TextTrimming="CharacterEllipsis"
                                   TextWrapping="Wrap"
                                   TextOptions.TextFormattingMode="Display" />
                    </StackPanel>
                </Grid>

                <Border x:Name="StatusMessagePanel"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        MaxWidth="640"
                        Background="{DynamicResource PanelBackground}"
                        BorderBrush="{DynamicResource PanelBorder}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="18,12"
                        Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock x:Name="StatusMessageText"
                                   Text=""
                                   Foreground="{DynamicResource TextPrimary}"
                                   FontSize="14"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap" />
                        <StackPanel x:Name="UpdateProgressPanel"
                                    Margin="0,11,0,0"
                                    HorizontalAlignment="Center"
                                    Visibility="Collapsed">
                            <ProgressBar x:Name="UpdateProgressBar"
                                         Style="{StaticResource UpdateProgressBarStyle}" />
                            <TextBlock x:Name="UpdateProgressDetailsText"
                                       Margin="0,7,0,0"
                                       Foreground="{DynamicResource TextSecondary}"
                                       FontSize="12"
                                       TextAlignment="Center"
                                       TextOptions.TextFormattingMode="Display" />
                            <Button x:Name="CancelUpdateButton"
                                    Style="{StaticResource UpdateCancelButtonStyle}"
                                    Click="CancelUpdateButton_Click" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border x:Name="PreviewOnlyBadge"
                Grid.Row="1"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Margin="12,12,0,0"
                Background="{DynamicResource BadgeBackground}"
                BorderBrush="{DynamicResource BadgeBorder}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="9,5"
                Visibility="Collapsed">
            <TextBlock x:Name="PreviewOnlyText"
                       Text=""
                       Foreground="{DynamicResource BadgeForeground}"
                       FontSize="12" />
        </Border>

        <Border x:Name="RotationActionsDock"
                Grid.Row="1"
                Margin="0,0,0,10"
                Padding="4"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Background="{DynamicResource PanelBackground}"
                BorderBrush="{DynamicResource PanelBorder}"
                BorderThickness="1"
                CornerRadius="10"
                SnapsToDevicePixels="True"
                Visibility="Collapsed">
            <Border.Effect>
                <DropShadowEffect Color="#000000"
                                  Direction="270"
                                  ShadowDepth="2"
                                  BlurRadius="12"
                                  Opacity="0.20" />
            </Border.Effect>
            <StackPanel Orientation="Horizontal">
                <Button x:Name="ResetRotationButton"
                        Style="{StaticResource RotationActionButtonStyle}"
                        Click="ResetRotationButton_Click" />
                <Button x:Name="ApplyRotationButton"
                        Style="{StaticResource RotationActionButtonStyle}"
                        Background="{DynamicResource AccentCheckBackground}"
                        BorderBrush="{DynamicResource AccentCheckBorder}"
                        Click="ApplyRotationButton_Click" />
            </StackPanel>
        </Border>

        <Border x:Name="ToolbarHost"
                Grid.Row="2"
                Background="Transparent"
                BorderThickness="0">
            <Grid Margin="10,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border x:Name="NavigationDock"
                        Grid.Column="1"
                        Margin="0,0,0,2"
                        Padding="5,4"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="{DynamicResource PanelBackground}"
                        BorderBrush="{DynamicResource PanelBorder}"
                        BorderThickness="1"
                        CornerRadius="10"
                        SnapsToDevicePixels="True">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000"
                                          Direction="270"
                                          ShadowDepth="1"
                                          BlurRadius="8"
                                          Opacity="0.10" />
                    </Border.Effect>
                    <Grid VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="122" />
                            <ColumnDefinition Width="13" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="13" />
                            <ColumnDefinition Width="122" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0"
                                    HorizontalAlignment="Right"
                                    Orientation="Horizontal">
                            <Button x:Name="ShowInFolderButton"
                                    Style="{StaticResource DockButtonStyle}"
                                    Click="ShowInFolderButton_Click" />
                            <Button x:Name="ZoomPopupButton"
                                    Style="{StaticResource DockButtonStyle}"
                                    Click="ZoomPopupButton_Click" />
                            <Button x:Name="ActualPixelsButton"
                                    Style="{StaticResource DockButtonStyle}"
                                    Click="ActualPixelsButton_Click" />
                        </StackPanel>

                        <Rectangle Grid.Column="1"
                                   Width="1"
                                   Height="18"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Fill="{DynamicResource PanelSeparator}" />

                        <StackPanel Grid.Column="2"
                                    HorizontalAlignment="Center"
                                    Orientation="Horizontal">
                            <Button x:Name="PreviousButton"
                                    Style="{StaticResource DockButtonStyle}"
                                    Click="PreviousButton_Click" />
                            <TextBlock x:Name="ImagePositionText"
                                       MinWidth="52"
                                       Margin="5,0"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextSecondary}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       TextAlignment="Center"
                                       Visibility="Collapsed" />
                            <Button x:Name="NextButton"
                                    Style="{StaticResource DockButtonStyle}"
                                    Click="NextButton_Click" />
                        </StackPanel>

                        <Rectangle Grid.Column="3"
                                   Width="1"
                                   Height="18"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Fill="{DynamicResource PanelSeparator}" />

                        <StackPanel Grid.Column="4"
                                    HorizontalAlignment="Left"
                                    Orientation="Horizontal">
                            <Button x:Name="RotateLeftButton"
                                    Style="{StaticResource DockButtonStyle}"
                                    Click="RotateLeftButton_Click" />
                            <Button x:Name="RotateRightButton"
                                    Style="{StaticResource DockButtonStyle}"
                                    Click="RotateRightButton_Click" />
                            <Button x:Name="DeleteButton"
                                    Style="{StaticResource DockButtonStyle}"
                                    Click="DeleteButton_Click" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Popup x:Name="ZoomPopup"
                       Grid.Column="1"
                       AllowsTransparency="True"
                       Placement="Top"
                       PlacementTarget="{Binding ElementName=ZoomPopupButton}"
                       PopupAnimation="Fade"
                       StaysOpen="False">
                    <Border Padding="10,8"
                            Background="{DynamicResource PanelBackground}"
                            BorderBrush="{DynamicResource PanelBorder}"
                            BorderThickness="1"
                            CornerRadius="10"
                            SnapsToDevicePixels="True">
                        <Border.Effect>
                            <DropShadowEffect Color="#000000"
                                              Direction="270"
                                              ShadowDepth="2"
                                              BlurRadius="12"
                                              Opacity="0.20" />
                        </Border.Effect>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="ZoomText"
                                       Style="{StaticResource ZoomPopupTextStyle}" />
                            <Slider x:Name="ZoomSlider"
                                    Style="{StaticResource DockZoomSliderStyle}"
                                    ValueChanged="ZoomSlider_ValueChanged" />
                        </StackPanel>
                    </Border>
                </Popup>
            </Grid>
        </Border>
    </Grid>
</Window>
